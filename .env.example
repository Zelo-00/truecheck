# === check / «Сверка» — пример окружения (без секретов) ===
AI_ENABLE=true
AI_PROVIDER=openai
AI_TIMEOUT=30
OPENAI_API_KEY=
OPENAI_BASE_URL=https://open.blackroute.space/v1
OPENAI_MODEL=gemini-3.5-flash
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
VERIFY_AI=true
VERIFY_TEMPERATURE=0
VERIFY_MIN_QUOTE_CHARS=24
FETCH_SOURCES=true
FETCH_TIMEOUT=20
MAX_UPLOAD_MB=40
DATA_DIR=/data
